{
    "hooks": {
        "PreToolUse": [
            {
                "matcher": "Bash",
                "command": ".claude/hooks/check-no-secrets.sh"
            }
        ],
        "PostToolUse": [
            {
                "matcher": "Edit",
                "command": "npx prettier --write \"$FILEPATH\""
            }
        ],
        "UserPromptSubmit": [
            {
                "command": ".claude/hooks/git-context.sh"
            }
        ]
    },
    "permissions": {
        "allow": [
            "Read",
            "Edit",
            "MultiEdit",
            "Write",
            "Bash(npm run *)",
            "Bash(npx prettier *)",
            "Bash(npx vitest *)",
            "Bash(npx playwright *)",
            "Bash(git status)",
            "Bash(git diff *)",
            "Bash(git log *)",
            "Bash(git add *)",
            "Bash(git commit *)",
            "Bash(cat *)",
            "Bash(ls *)",
            "Bash(find *)",
            "Bash(grep *)"
        ],
        "deny": [
            "Bash(rm -rf *)",
            "Bash(sudo *)",
            "Bash(curl * | bash)",
            "Bash(wget * | bash)"
        ]
    }
}