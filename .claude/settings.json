{
    "hooks": {
        "PreToolUse": [
            {
                "matcher": {
                    "tools": [
                        "BashTool"
                    ]
                },
                "hooks": [
                    {
                        "type": "command",
                        "command": ".claude/hooks/check-no-secrets.sh"
                    }
                ]
            }
        ],
        "PostToolUse": [
            {
                "matcher": {
                    "tools": [
                        "EditTool",
                        "MultiEditTool",
                        "WriteTool"
                    ]
                },
                "hooks": [
                    {
                        "type": "command",
                        "command": "npx prettier --write \"$FILEPATH\""
                    }
                ]
            }
        ],
        "UserPromptSubmit": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": ".claude/hooks/git-context.sh"
                    }
                ]
            }
        ]
    },
    "permissions": {
        "allow": [
            "Read",
            "Edit",
            "MultiEdit",
            "Write",
            "Bash(npm run *)",
            "Bash(npx prettier *)",
            "Bash(npx vitest *)",
            "Bash(npx playwright *)",
            "Bash(git status)",
            "Bash(git diff *)",
            "Bash(git log *)",
            "Bash(git add *)",
            "Bash(git commit *)",
            "Bash(cat *)",
            "Bash(ls *)",
            "Bash(find *)",
            "Bash(grep *)"
        ],
        "deny": [
            "Bash(rm -rf *)",
            "Bash(sudo *)",
            "Bash(curl * | bash)",
            "Bash(wget * | bash)"
        ]
    }
}